    {
      "id": "post-001",
      "title": "How to Give Your Plants the Right Light",
      "slug": "proper-light-for-plants",
      "image": "/prod2.jpeg",
      "excerpt": "Light plays a key role in plant growth. Most indoor plants prefer indirect sunlight.",
      "content": "Most indoor plants thrive in bright, indirect light. Direct sunlight can burn leaves, while too little light slows growth. Place your plant near a window with filtered light and rotate it regularly to ensure even growth.",
      "tags": [
        "light",
        "indoor"
      ],
      "createdAt": "2026-04-30"
    },
    {
      "id": "post-002",
      "title": "Stop Overwatering Your Plants",
      "slug": "avoid-overwatering",
      "image": "/prod3.jpeg",
      "excerpt": "Overwatering is one of the most common mistakes plant owners make.",
      "content": "Water your plants only when the top layer of soil is dry. Overwatering can lead to root rot and plant death. Always check the soil before watering and ensure your pot has proper drainage.",
      "tags": [
        "watering",
        "beginner"
      ],
      "createdAt": "2026-04-30"
    },
    {
      "id": "post-003",
      "title": "Choosing the Right Soil for Your Plants",
      "slug": "best-soil-for-plants",
      "image": "/prod4.jpeg",
      "excerpt": "Soil quality directly affects plant health and growth.",
      "content": "Using well-draining soil is essential for healthy plants. A good mix allows air and water to flow properly, preventing root rot. Adding materials like perlite can improve drainage and aeration.",
      "tags": [
        "soil",
        "care"
      ],
      "createdAt": "2026-04-30"
    }
